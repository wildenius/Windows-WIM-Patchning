{
  "Version": "1.0.0",
  "Root": "C:\\BuildWimV2",
  "Input": {
    "AutoPickFirst": true,
    "PreferredImageFileNames": [
      "install.wim",
      "install.esd"
    ],
    "IsoSearchRelativePaths": [
      "sources\\install.wim",
      "sources\\install.esd"
    ]
  },
  "Updates": {
    "Folder": "Updates",
    "AllowedExtensions": [
      ".msu",
      ".cab"
    ],
    "DirectMsuServicing": true
  },
  "Defender": {
    "InjectLatestOfflineUpdate": false,
    "DownloadLatest": true,
    "Architecture": "x64",
    "UpdateKitUrl": "https://go.microsoft.com/fwlink/?linkid=2144531"
  },
  "Output": {
    "InstallWimName": "install.wim",
    "SplitBaseName": "install.swm",
    "SplitSizeMB": 3800,
    "EmitMetadataJson": false
  },
  "Servicing": {
    "RequireProExportBeforePatch": true,
    "EditionNameMatch": "Windows 11 Pro",
    "CleanupStartComponentCleanup": true,
    "CleanupResetBase": true,
    "ScratchDir": "Temp\\Scratch"
  },
  "Logging": {
    "LogLevel": "Info",
    "IncludeDebugDismOutput": true
  },
  "Safety": {
    "MinFreeSpaceGB": 45,
    "ForceCleanupWim": true
  }
}
